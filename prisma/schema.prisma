generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubTier {
  PAYG
  MONTHLY
  PLUS
}

enum FreshBoxSize {
  SMALL
  MEDIUM
  LARGE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  passwordHash  String
  isAdmin       Boolean        @default(false)
  createdAt     DateTime       @default(now())

  // Subscription / billing
  stripeCustomerId String? @unique

  // Referral programme
  referralCode     String?  @unique
  referredById     String?
  referredBy       User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]   @relation("Referrals")
  referralRewarded Boolean  @default(false)
  creditCents      Int      @default(0)

  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  orders        Order[]
  subscription  Subscription?
  freshBox      FreshBoxSubscription?
}

model FreshBoxSubscription {
  id                   String       @id @default(cuid())
  userId               String       @unique
  size                 FreshBoxSize @default(MEDIUM)
  // 1 = Monday, 2 = Tuesday, 3 = Wednesday (orders processed Mon–Wed only)
  deliveryWeekday      Int          @default(2)
  status               String       @default("active") // active | past_due | canceled
  stripeSubscriptionId String?      @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  tier                 SubTier   @default(PAYG)
  status               String    @default("active") // active | past_due | canceled
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String
  // price stored in minor units (pence) to avoid float rounding issues
  priceCents     Int
  currency       String   @default("gbp")
  imageUrl       String
  category       String
  brand          String? // brand / source, e.g. "Baskt Private Label"
  isPrivateLabel Boolean  @default(false)
  stock          Int      @default(100)
  createdAt      DateTime @default(now())

  cartItems         CartItem[]
  wishlistItems     WishlistItem[]
  orderItems        OrderItem[]
  recipeIngredients RecipeIngredient[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

model Order {
  id                 String      @id @default(cuid())
  userId             String
  status             OrderStatus @default(PENDING)
  // subtotal of items before discounts/delivery
  subtotalCents      Int         @default(0)
  discountCents      Int         @default(0)
  deliveryCents      Int         @default(0)
  creditAppliedCents Int         @default(0)
  totalCents         Int
  currency           String      @default("gbp")
  stripeSessionId    String?     @unique
  createdAt          DateTime    @default(now())
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items              OrderItem[]
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  quantity       Int
  // snapshot of price at purchase time
  unitPriceCents Int
  nameSnapshot   String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product @relation(fields: [productId], references: [id])
}

model Recipe {
  id          String             @id @default(cuid())
  slug        String             @unique
  title       String
  description String
  imageUrl    String
  steps       String[]
  servings    Int                @default(4)
  minutes     Int                @default(45)
  isPremium   Boolean            @default(false) // Plus-only recipe
  createdAt   DateTime           @default(now())
  ingredients RecipeIngredient[]
}

model RecipeIngredient {
  id        String   @id @default(cuid())
  recipeId  String
  productId String? // tappable link to a stocked product (null for pantry basics)
  label     String // display text, e.g. "2 cups long-grain rice"
  sortOrder Int      @default(0)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}
